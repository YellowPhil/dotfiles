function arrayUnique( ar ) {
	var a = [];
	var l = ar.length;
	for (var i = 0; i < l; i++) {
		for (var j = i+1; j < l; j++) {
			if (ar[i] === ar[j]) j = ++i;
		}
		a.push(ar[i]);
	}
	return a;
