gui.geom.ProfileDialog.x: 665
gui.geom.ProfileDialog.y: 300
gui.geom.ProfileDialog.width: 955
gui.geom.ProfileDialog.height: 1029
# TRUE or FALSE (case-insensitive).
gui.geom.ProfileDialog.maximized: FALSE

# Geometry and maximized state of PacketDialog window.
