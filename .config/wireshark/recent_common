gui.geom.PacketDialog.x: 568
gui.geom.PacketDialog.y: 89
gui.geom.PacketDialog.width: 636
gui.geom.PacketDialog.height: 1029
# TRUE or FALSE (case-insensitive).
gui.geom.PacketDialog.maximized: FALSE

# Geometry and maximized state of PreferencesDialog window.
# Decimal integers.
gui.geom.PreferencesDialog.x: 0
gui.geom.PreferencesDialog.y: 0
gui.geom.PreferencesDialog.width: 955
gui.geom.PreferencesDialog.height: 1029
# TRUE or FALSE (case-insensitive).
gui.geom.PreferencesDialog.maximized: FALSE

